# Codebuff / Freebuff upstream Bearer token.
# Required. Use the token body only, without the "Bearer " prefix.
# Multiple accounts can be separated by commas.
FREEBUFF_TOKEN=

# Local OpenAI-compatible API access key.
# Required for /v1/* APIs in this managed build.
FREEBUFF_API_KEY=

# Admin panel login key for /admin.
# Change this before public deployment.
FREEBUFF_ADMIN_KEY=sk-admin

# Freebuff upstream API root.
FREEBUFF_API_BASE_URL=https://www.codebuff.com

# Ad provider order. The service tries each provider before creating a session.
FREEBUFF_AD_PROVIDERS=gravity,zeroclick

# Upstream HTTP request timeout in seconds.
FREEBUFF_TIMEOUT=60

# false: direct upstream requests and ignore system HTTP_PROXY / HTTPS_PROXY.
# true: route upstream requests through FREEBUFF_PROXY_URL.
FREEBUFF_PROXY_ENABLED=false

# Supports http://, https://, socks5://, and socks5h://.
FREEBUFF_PROXY_URL=

# Debug logging.
FREEBUFF_DEBUG=false
FREEBUFF_LOG_LEVEL=INFO
FREEBUFF_LOG_BODY_CHARS=2000
FREEBUFF_LOG_COLOR=true

# Admin in-memory log retention.
FREEBUFF_ADMIN_LOG_LINES=1000

# Service bind address and port.
FREEBUFF_HOST=0.0.0.0
FREEBUFF_PORT=8000

# Simulated client device info.
FREEBUFF_TIMEZONE=Asia/Shanghai
FREEBUFF_LOCALE=zh-CN
FREEBUFF_OS=windows
